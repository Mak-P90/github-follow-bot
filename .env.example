# ======================================================
# GitHub Follower Bot - environment template
# Copy to .env and replace placeholder values.
# ======================================================

# Required in all modes
GITHUB_USER=your_github_username

# Authentication mode (optional, runtime can infer if omitted)
# Valid: pat | github_app_installation_token | github_app
BOT_AUTH_MODE=pat

# --- Mode: pat ---
PERSONAL_GITHUB_TOKEN=ghp_replace_me

# --- Mode: github_app_installation_token ---
# GITHUB_APP_INSTALLATION_TOKEN=ghs_replace_me

# --- Mode: github_app (enterprise runtime token exchange) ---
# GITHUB_APP_ID=12345
# GITHUB_APP_INSTALLATION_ID=67890
# Choose exactly one private key source:
# 1) Inline PEM
# GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# 2) File path (single path or fallback candidates separated by comma/colon)
# GITHUB_APP_PRIVATE_KEY_FILE=/run/secrets/github_app_private_key_next.pem,/run/secrets/github_app_private_key.pem
# 3) Command returning PEM via stdout
# GITHUB_APP_PRIVATE_KEY_COMMAND=python -c "print(open('/run/secrets/github_app_private_key.pem').read())"
# BOT_GITHUB_APP_KEY_COMMAND_TIMEOUT_SECONDS=10
# BOT_GITHUB_APP_TOKEN_REFRESH_SKEW_SECONDS=60

# Optional hard enforcement
# BOT_REQUIRE_GITHUB_APP_AUTH=false

# Runtime
BOT_DB_ENGINE=sqlite
BOT_DB_PATH=runtime/data/bot_state.db
BOT_DRY_RUN=true
BOT_MAX_FOLLOWS_PER_RUN=50
BOT_MAX_FORKS_PER_RUN=25
BOT_MAX_CANDIDATES_PER_RUN=200
BOT_MAX_API_CALLS_PER_RUN=500
BOT_MAX_EXPAND_SEEDS_PER_RUN=50
BOT_EXPAND_HTTP_ERROR_WINDOW=5
BOT_EXPAND_HTTP_ERROR_THRESHOLD=3
BOT_EXPAND_FALLBACK_TO_FOLLOWERS=false
BOT_DISCOVERY_MODE=followers
BOT_FOLLOW_JOB_MAX_ATTEMPTS=3
# BOT_VERIFY_FOLLOW_AFTER_PUT=true
# BOT_FOLLOW_VERIFY_MAX_RETRIES=2
# BOT_FOLLOW_VERIFY_RETRY_DELAY_SECONDS=1.0
BOT_CLEANUP_LEGACY_FILES=true

# Queue backend
# BOT_QUEUE_BACKEND=sqlite
# BOT_RABBITMQ_AMQP_URL=amqp://guest:guest@localhost:5672/
# BOT_RABBITMQ_QUEUE=follow_jobs
# BOT_RABBITMQ_DLQ=follow_jobs.dead_letter

# GUI
# BOT_GUI_ENABLED=false
# BOT_GUI_HOST=127.0.0.1
# BOT_GUI_PORT=8081
# BOT_GUI_LOCALE=en

# Policy engine
# BOT_POLICY_REQUIRE_CONSENT=false
# BOT_POLICY_DENYLIST=user1,user2
# BOT_POLICY_RETENTION_DAYS=365

# Release manifest integrity
# RELEASE_MANIFEST_SIGNING_KEY=change-me
# RELEASE_MANIFEST_REQUIRE_SIGNATURE=false
# RELEASE_MANIFEST_MAX_AGE_SECONDS=300

# Observability / OTel
# BOT_OTEL_ENABLED=false
# OTEL_SERVICE_NAME=github_follower_bot
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# APP_ENV=local

# Zero-trust / cosign
# BOT_COSIGN_ENABLED=false
# COSIGN_KEY_REF=cosign.pub

# Migration / dual-write
# BOT_DUAL_WRITE_DRY_RUN=false
# BOT_POSTGRES_DSN=postgresql://user:pass@localhost:5432/github_follower_bot
